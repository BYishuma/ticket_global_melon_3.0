{
    "manifest_version": 3,
    "name": "ticket_global_melon",
    "description": "melon ticket extension_humanlike_maxSeats_prioritized",
    "version": "3.0.0",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://script.google.com/*",
        "https://tkglobal.melon.com/*"
    ],
	"web_accessible_resources": [
		{ "resources": ["inject.js"], "matches": ["https://tkglobal.melon.com/*"] },
		{ "resources": ["assets/house_lo.mp3"], "matches": ["https://tkglobal.melon.com/*"] }
    ],
    "content_scripts": [
        {
            "matches": [
                "https://tkglobal.melon.com/reservation/popup/onestop.htm*"
            ],
            "js": ["content/dialog-handler.js"],
            "run_at": "document_start",
            "all_frames": true
        },
        {
            "matches": [
                "https://tkglobal.melon.com/reservation/popup/onestop.htm*"
            ],
            "js": ["content/storage.js", "content/sleep.js", "content/email.js", "content/seat.js"],
            "run_at": "document_end"
        },
        {
            "matches": [
                "https://tkglobal.melon.com/performance/index.htm*"
            ],
            "js": ["content/hourToPm.js", "content/storage.js", "content/sleep.js", "content/concert.js"],
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup/mainpage/index.html",
		"default_icon": {
		        "16": "assets/logo.png",
		        "32": "assets/logo.png",
		        "48": "assets/logo.png"
		    }
		},
		"icons": {
			   "16": "assets/logo.png",
			   "32": "assets/logo.png",
			   "48": "assets/logo.png"
		}
	}